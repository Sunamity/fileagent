{
  "name": "@fileagent/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for FileAgent — convert any file to markdown for LLMs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured'",
    "test": "vitest run"
  },
  "peerDependencies": {
    "ai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ai": "^4.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "fileagent",
    "document",
    "markdown",
    "llm",
    "ai",
    "conversion"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sunamity/fileagent.git"
  },
  "homepage": "https://fileagent.dev",
  "bugs": {
    "url": "https://github.com/Sunamity/fileagent/issues"
  }
}
